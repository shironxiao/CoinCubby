<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="110dp"
    android:background="@drawable/bg_card_rounded"
    android:backgroundTint="@color/cc_card_bg"
    android:padding="16dp"
    android:layout_margin="8dp"
    android:clickable="true"
    android:focusable="true"
    android:stateListAnimator="@animator/nav_item_press">

    <TextView
        android:id="@+id/tvLockerId"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="S1"
        android:textColor="#525B44"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/tvSize"
        app:layout_constraintHorizontal_bias="0" />

    <TextView
        android:id="@+id/tvPrice"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="₱ 10/hr"
        android:textColor="#525B44"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvLockerId"
        app:layout_constraintEnd_toStartOf="@+id/tvSize"
        app:layout_constraintHorizontal_bias="0" />

    <TextView
        android:id="@+id/tvSize"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_size_pill"
        android:paddingHorizontal="14dp"
        android:paddingVertical="6dp"
        android:text="Small"
        android:textColor="@color/white"
        android:textSize="10sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
