<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:weightSum="3">

    <!-- Available -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginEnd="6dp"
        android:background="@drawable/bg_wallet_card"
        android:padding="16dp">

        <ImageView
            android:id="@+id/available_icon"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/bg_wallet_pill"
            android:backgroundTint="#B5D68E"
            android:padding="8dp"
            android:src="@drawable/ic_lock"
            app:tint="@color/black"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/available_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Available"
            android:textColor="@color/cc_text_secondary"
            android:textSize="10sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="S1, S2, S3, S4, M1"
            android:textColor="@color/cc_text_primary"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/available_label" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Occupied -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginHorizontal="3dp"
        android:background="@drawable/bg_wallet_card"
        android:padding="16dp">

        <ImageView
            android:id="@+id/occupied_icon"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/bg_wallet_pill"
            android:backgroundTint="#F0A3A3"
            android:padding="8dp"
            android:src="@drawable/ic_lock"
            app:tint="@color/black"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/occupied_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Occupied"
            android:textColor="@color/cc_text_secondary"
            android:textSize="10sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="L1, L2"
            android:textColor="@color/cc_text_primary"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/occupied_label" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Pending -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="6dp"
        android:background="@drawable/bg_wallet_card"
        android:padding="16dp">

        <ImageView
            android:id="@+id/pending_icon"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/bg_wallet_pill"
            android:backgroundTint="#F7B27B"
            android:padding="8dp"
            android:src="@drawable/ic_clock"
            app:tint="@color/black"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/pending_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Pending"
            android:textColor="@color/cc_text_secondary"
            android:textSize="10sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="M2"
            android:textColor="@color/cc_text_primary"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/pending_label" />
    </androidx.constraintlayout.widget.ConstraintLayout>

</LinearLayout>
