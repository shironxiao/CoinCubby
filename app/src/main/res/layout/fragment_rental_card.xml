<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="220dp"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card_rounded"
    android:backgroundTint="@color/cc_card_bg"
    android:padding="20dp"
    android:layout_marginEnd="16dp">

    <TextView
        android:id="@+id/tvInUse"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/in_use"
        android:textColor="@color/cc_text_secondary"
        android:textSize="13sp"
        android:fontFamily="sans-serif-medium"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvLocation"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/locker_location"
        android:textColor="@color/cc_text_primary"
        android:textSize="13sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvInUse" />

    <TextView
        android:id="@+id/tvLockerId"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="locker M2"
        android:textColor="@color/cc_text_primary"
        android:textSize="13sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvLocation" />

    <LinearLayout
        android:id="@+id/llAccessBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_access_code_box"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@+id/tvLockerId">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/access_code"
            android:textColor="@color/cc_text_secondary"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/tvAccessCode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="7 8 7 8"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold"
            android:letterSpacing="0.2" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvTimeCost"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/rental_time_cost"
        android:textColor="@color/cc_text_secondary"
        android:textSize="11sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/llAccessBox" />

</androidx.constraintlayout.widget.ConstraintLayout>
